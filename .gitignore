# ===== Tessera-specific =====

# Training corpus — never commit (GBs of data, downloaded externally)
/corpus/*
!/corpus/.gitkeep

# Trained tokenizers — generated artifacts, not source
*.tessera.json
/tessera.json
/tessera-*.json
!/tessera-core/src/test/resources/**/*.json

# Locally generated benchmarks and reports
/benchmark-results/
/coverage/

# Publishing credentials — NEVER commit
local.properties
gradle.properties.local
publish.gradle.properties
secring.gpg
*.gpg
**/secrets.properties

# Dependency caches
.kotlin/
kotlin-js-store/
